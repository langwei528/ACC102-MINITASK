    "                     'Total Rev ($M)': round(prem_rev+free_rev,2),\n",
    "                     'Rev/Song ($M)': round((prem_rev+free_rev)/len(sub),2)})\n",
    "\n",
    "rev_df = pd.DataFrame(rev_data).set_index('Genre')\n",
