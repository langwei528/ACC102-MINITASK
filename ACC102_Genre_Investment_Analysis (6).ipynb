   "outputs": [],
   "source": [
    "# ── 3. Filter to Focus Genres ─────────────────────────────────────────────────\n",
    "df_focus = df[df[GENRE_COL].isin(FOCUS_GENRES)].copy()\n",
    "print(f\"Filtered to {len(FOCUS_GENRES)} genres: {FOCUS_GENRES}\")\n",
    "print(f\"Observations: {len(df_focus)} ({len(df_focus)/len(df)*100:.1f}% of total)\")\n",
    "print(f\"\\nBreakdown:\\n{df_focus[GENRE_COL].value_counts()}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "919a4214",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Figure 4: Focus Genres — Business Performance Dashboard ──────────────────\n",
    "fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
    "fig.suptitle(f'Business Performance Dashboard: {\" vs \".join(FOCUS_GENRES)}',\n",
    "             fontsize=16, fontweight='bold', y=1.01)\n",
    "\n",
    "panels = [\n",
    "    (STREAM_COL, 'Avg Total Streams (M)', 'Streaming volume'),\n",
